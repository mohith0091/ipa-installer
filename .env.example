PORT=3000
BASE_URL=https://your-domain.com
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=1048576000
RETENTION_HOURS=48

# Storage type: "local" or "s3"
STORAGE_TYPE=local

# S3 Configuration (only required when STORAGE_TYPE=s3)
S3_ENDPOINT=                # Custom endpoint for self-hosted S3 (e.g., https://minio.example.com). Leave empty for AWS.
S3_REGION=us-east-1
S3_BUCKET=ipa-installer
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false   # Set to true for MinIO / self-hosted S3
